{
  "name": "lesion-network-mapping-webapp",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "node scripts/check-syntax.mjs",
    "test": "npm run lint && npm run test:tasks && npm run test:manifest && npm run test:parcel-overlap && npm run test:overlap-export && npm run test:volume-utils && npm run test:brain-extraction && npm run test:app && npm run test:html",
    "test:volume-utils": "node scripts/test_volume_utils.cjs",
    "test:brain-extraction": "node scripts/test_brain_extraction.cjs",
    "test:tasks": "node --no-warnings scripts/test_lnm_tasks.mjs",
    "test:manifest": "node --no-warnings scripts/test_lnm_manifest.mjs",
    "test:parcel-overlap": "node scripts/test_parcel_overlap.cjs",
    "test:overlap-export": "node scripts/test_overlap_export.cjs",
    "test:app": "node --no-warnings scripts/test_lnm_app.mjs",
    "test:html": "node --no-warnings scripts/test_index_html.mjs",
    "test:smoke": "node --test --test-timeout=180000 scripts/test_browser_smoke.mjs"
  },
  "dependencies": {
    "nifti-reader-js": "^0.8.0",
    "onnxruntime-node": "^1.24.3"
  },
  "devDependencies": {
    "acorn": "^8.16.0",
    "playwright": "^1.49.0"
  }
}
